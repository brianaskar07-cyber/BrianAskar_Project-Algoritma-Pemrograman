<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FIRE.MainDashboardPage"
             Title="Dashboard"
             BackgroundColor="#F6F7F9">

    <ScrollView VerticalScrollBarVisibility="Always">
        <Grid Padding="32"
              RowDefinitions="Auto,Auto"
              RowSpacing="24">

            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">

                <VerticalStackLayout Spacing="6">
                    <Label x:Name="LabelDashboardTitle"
                           Text="Dashboard Monitoring Kebakaran"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#1F2937"
                           LineBreakMode="WordWrap" />

                    <Label x:Name="LabelDashboardSubtitle"
                           Text="Sistem peringatan dini kebakaran berbasis parameter lingkungan."
                           FontSize="14"
                           TextColor="#667085"
                           LineBreakMode="WordWrap" />

                    <Label x:Name="LabelWelcome"
                           Text="Selamat datang. Sistem berhasil memverifikasi identitas Anda."
                           FontSize="14"
                           TextColor="#667085"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>

                <Border Grid.Column="1"
                        BackgroundColor="#FFF1E8"
                        StrokeThickness="0"
                        Padding="16,10"
                        VerticalOptions="Start"
                        StrokeShape="RoundRectangle 22">

                    <VerticalStackLayout Spacing="4"
                                         HorizontalOptions="Center">

                        <Label x:Name="LabelRoleBadge"
                               Text="OPERATOR"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="#E8752F"
                               HorizontalTextAlignment="Center" />

                        <Label x:Name="lblStatus"
                               Text="NORMAL"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="#15803D"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid Grid.Row="1"
                  ColumnDefinitions="280,*"
                  ColumnSpacing="24">

                <Border x:Name="SidebarPanel"
                        Grid.Column="0"
                        BackgroundColor="White"
                        Stroke="#E5E7EB"
                        StrokeThickness="1"
                        Padding="24"
                        StrokeShape="RoundRectangle 18"
                        VerticalOptions="Start">

                    <Grid RowDefinitions="Auto,*,Auto"
                          HeightRequest="700">

                        <VerticalStackLayout Grid.Row="0"
                                             Spacing="14">

                            <Border BackgroundColor="#EAF0F6"
                                    StrokeThickness="0"
                                    WidthRequest="64"
                                    HeightRequest="64"
                                    HorizontalOptions="Start"
                                    StrokeShape="RoundRectangle 18">

                                <Label Text="F"
                                       FontSize="28"
                                       TextColor="#1E3A5F"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="FIRE System"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#1F2937" />

                                <Label Text="Early Fire Warning System"
                                       FontSize="13"
                                       TextColor="#667085" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="1"
                                             Spacing="10"
                                             Margin="0,34,0,0">

                            <Border x:Name="MenuMonitoring"
                                    BackgroundColor="#EAF0F6"
                                    StrokeThickness="0"
                                    Padding="14,12"
                                    StrokeShape="RoundRectangle 12">

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMenuMonitoringTapped" />
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="10">

                                    <BoxView x:Name="DotMenuMonitoring"
                                             WidthRequest="8"
                                             HeightRequest="8"
                                             CornerRadius="4"
                                             Color="#1E3A5F"
                                             VerticalOptions="Center" />

                                    <Label x:Name="LabelMenuMonitoring"
                                           Grid.Column="1"
                                           Text="Monitoring"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#1E3A5F" />
                                </Grid>
                            </Border>

                            <Border x:Name="MenuParameterSensor"
                                    BackgroundColor="Transparent"
                                    StrokeThickness="0"
                                    Padding="14,12"
                                    StrokeShape="RoundRectangle 12">

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMenuParameterSensorTapped" />
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="10">

                                    <BoxView x:Name="DotMenuParameterSensor"
                                             WidthRequest="8"
                                             HeightRequest="8"
                                             CornerRadius="4"
                                             Color="#D9DEE7"
                                             VerticalOptions="Center" />

                                    <Label x:Name="LabelMenuParameterSensor"
                                           Grid.Column="1"
                                           Text="Parameter Sensor"
                                           FontSize="14"
                                           TextColor="#667085" />
                                </Grid>
                            </Border>

                            <Border x:Name="MenuStatusBahaya"
                                    BackgroundColor="Transparent"
                                    StrokeThickness="0"
                                    Padding="14,12"
                                    StrokeShape="RoundRectangle 12">

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMenuStatusBahayaTapped" />
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="10">

                                    <BoxView x:Name="DotMenuStatusBahaya"
                                             WidthRequest="8"
                                             HeightRequest="8"
                                             CornerRadius="4"
                                             Color="#D9DEE7"
                                             VerticalOptions="Center" />

                                    <Label x:Name="LabelMenuStatusBahaya"
                                           Grid.Column="1"
                                           Text="Status Bahaya"
                                           FontSize="14"
                                           TextColor="#667085" />
                                </Grid>
                            </Border>

                            <Border x:Name="MenuDataPengguna"
                                    BackgroundColor="Transparent"
                                    StrokeThickness="0"
                                    Padding="14,12"
                                    StrokeShape="RoundRectangle 12">

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMenuDataPenggunaTapped" />
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="10">

                                    <BoxView x:Name="DotMenuDataPengguna"
                                             WidthRequest="8"
                                             HeightRequest="8"
                                             CornerRadius="4"
                                             Color="#D9DEE7"
                                             VerticalOptions="Center" />

                                    <Label x:Name="LabelMenuDataPengguna"
                                           Grid.Column="1"
                                           Text="Data Pengguna"
                                           FontSize="14"
                                           TextColor="#667085" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <Button Grid.Row="2"
                                Text="Keluar"
                                HeightRequest="44"
                                BackgroundColor="White"
                                TextColor="#DC2626"
                                BorderColor="#E5E7EB"
                                BorderWidth="1"
                                CornerRadius="8"
                                Clicked="OnLogoutClicked" />
                    </Grid>
                </Border>

                <Grid Grid.Column="1"
                      ColumnDefinitions="*,380"
                      ColumnSpacing="18">

                    <VerticalStackLayout x:Name="OperatorPanel"
                                         Grid.Column="0"
                                         Spacing="18"
                                         VerticalOptions="Start">

                        <Grid ColumnDefinitions="*,*,*"
                              ColumnSpacing="18">

                            <Border Grid.Column="0"
                                    BackgroundColor="White"
                                    Stroke="#E5E7EB"
                                    StrokeThickness="1"
                                    Padding="24"
                                    StrokeShape="RoundRectangle 18">

                                <VerticalStackLayout Spacing="10">
                                    <Label Text="Suhu Lingkungan"
                                           FontSize="14"
                                           TextColor="#667085" />

                                    <Label x:Name="lblSuhu"
                                           Text="0°C"
                                           FontSize="34"
                                           FontAttributes="Bold"
                                           TextColor="#B91C1C" />

                                    <Label Text="Parameter panas area monitoring"
                                           FontSize="13"
                                           TextColor="#667085"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1"
                                    BackgroundColor="White"
                                    Stroke="#E5E7EB"
                                    StrokeThickness="1"
                                    Padding="24"
                                    StrokeShape="RoundRectangle 18">

                                <VerticalStackLayout Spacing="10">
                                    <Label Text="Kadar Asap"
                                           FontSize="14"
                                           TextColor="#667085" />

                                    <Label x:Name="lblAsap"
                                           Text="0 ppm"
                                           FontSize="34"
                                           FontAttributes="Bold"
                                           TextColor="#1E3A5F" />

                                    <Label Text="Indikator konsentrasi asap"
                                           FontSize="13"
                                           TextColor="#667085"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="2"
                                    BackgroundColor="White"
                                    Stroke="#E5E7EB"
                                    StrokeThickness="1"
                                    Padding="24"
                                    StrokeShape="RoundRectangle 18">

                                <VerticalStackLayout Spacing="10">
                                    <Label Text="Kelembapan"
                                           FontSize="14"
                                           TextColor="#667085" />

                                    <Label x:Name="lblHum"
                                           Text="0%"
                                           FontSize="34"
                                           FontAttributes="Bold"
                                           TextColor="#E8752F" />

                                    <Label Text="Kondisi kelembapan udara"
                                           FontSize="13"
                                           TextColor="#667085"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Border BackgroundColor="White"
                                Stroke="#E5E7EB"
                                StrokeThickness="1"
                                Padding="26"
                                StrokeShape="RoundRectangle 18">

                            <VerticalStackLayout Spacing="18">

                                <VerticalStackLayout Spacing="8">
                                    <Label Text="Analisis Risiko Kebakaran"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="#1F2937" />

                                    <Label Text="Panel operator menampilkan parameter teknis untuk memantau potensi kebakaran berdasarkan suhu, asap, dan kelembapan."
                                           FontSize="14"
                                           TextColor="#667085"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>

                                <BoxView HeightRequest="1"
                                         Color="#E5E7EB" />

                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="Tingkat Bahaya"
                                           FontSize="14"
                                           TextColor="#667085" />

                                    <Label x:Name="lblDanger"
                                           Grid.Column="1"
                                           Text="0%"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#1E3A5F" />
                                </Grid>

                                <ProgressBar x:Name="dangerBar"
                                             Progress="0"
                                             HeightRequest="8"
                                             ProgressColor="#E8752F"
                                             BackgroundColor="#E5E7EB" />

                                <Border BackgroundColor="#F6F7F9"
                                        StrokeThickness="0"
                                        Padding="18"
                                        StrokeShape="RoundRectangle 14">

                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="Keterangan Operator"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#1F2937" />

                                        <Label Text="Status NORMAL, WASPADA, dan BAHAYA ditentukan dari kombinasi parameter suhu, kadar asap, dan kelembapan."
                                               FontSize="13"
                                               TextColor="#667085"
                                               LineBreakMode="WordWrap" />
                                    </VerticalStackLayout>
                                </Border>

                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="12">

                                    <Border BackgroundColor="#EAF0F6"
                                            StrokeThickness="0"
                                            WidthRequest="44"
                                            HeightRequest="44"
                                            StrokeShape="RoundRectangle 12">

                                        <Label Text="1"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#1E3A5F"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="4">
                                        <Label Text="Pembacaan parameter lingkungan"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#1F2937" />

                                        <Label Text="Sensor membaca suhu, asap, dan kelembapan secara berkala."
                                               FontSize="13"
                                               TextColor="#667085"
                                               LineBreakMode="WordWrap" />
                                    </VerticalStackLayout>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="12">

                                    <Border BackgroundColor="#EAF0F6"
                                            StrokeThickness="0"
                                            WidthRequest="44"
                                            HeightRequest="44"
                                            StrokeShape="RoundRectangle 12">

                                        <Label Text="2"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#1E3A5F"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="4">
                                        <Label Text="Analisis tingkat bahaya"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#1F2937" />

                                        <Label Text="Nilai parameter diproses untuk menentukan kondisi aman, waspada, atau bahaya."
                                               FontSize="13"
                                               TextColor="#667085"
                                               LineBreakMode="WordWrap" />
                                    </VerticalStackLayout>
                                </Grid>

                                <Border BackgroundColor="#F8FAFC"
                                        Stroke="#E5E7EB"
                                        StrokeThickness="1"
                                        Padding="18"
                                        StrokeShape="RoundRectangle 16">

                                    <VerticalStackLayout Spacing="14">
                                        <Label Text="Analisis AI Lokal: Fuzzy &amp; Neural Network"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="#1F2937" />

                                        <Grid ColumnDefinitions="*,*"
                                              ColumnSpacing="14">

                                            <Border Grid.Column="0"
                                                    BackgroundColor="White"
                                                    StrokeThickness="0"
                                                    Padding="16"
                                                    StrokeShape="RoundRectangle 14">

                                                <VerticalStackLayout Spacing="6">
                                                    <Label Text="Fuzzy Logic"
                                                           FontSize="15"
                                                           FontAttributes="Bold"
                                                           TextColor="#1F2937" />

                                                    <Label x:Name="lblOperatorFuzzyStatus"
                                                           Text="Status: -"
                                                           FontSize="14"
                                                           FontAttributes="Bold"
                                                           TextColor="#15803D" />

                                                    <Label x:Name="lblOperatorFuzzyScore"
                                                           Text="Risiko fuzzy: -"
                                                           FontSize="13"
                                                           TextColor="#667085" />

                                                    <Label x:Name="lblOperatorFuzzyDetail"
                                                           Text="Aman: - • Waspada: - • Bahaya: -"
                                                           FontSize="12"
                                                           TextColor="#667085"
                                                           LineBreakMode="WordWrap" />
                                                </VerticalStackLayout>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    BackgroundColor="White"
                                                    StrokeThickness="0"
                                                    Padding="16"
                                                    StrokeShape="RoundRectangle 14">

                                                <VerticalStackLayout Spacing="6">
                                                    <Label Text="Neural Network"
                                                           FontSize="15"
                                                           FontAttributes="Bold"
                                                           TextColor="#1F2937" />

                                                    <Label x:Name="lblOperatorNnStatus"
                                                           Text="Status: -"
                                                           FontSize="14"
                                                           FontAttributes="Bold"
                                                           TextColor="#15803D" />

                                                    <Label x:Name="lblOperatorNnScore"
                                                           Text="Risiko NN: -"
                                                           FontSize="13"
                                                           TextColor="#667085" />

                                                    <Label x:Name="lblOperatorNnDetail"
                                                           Text="Menunggu data sensor."
                                                           FontSize="12"
                                                           TextColor="#667085"
                                                           LineBreakMode="WordWrap" />
                                                </VerticalStackLayout>
                                            </Border>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="18"
                                         VerticalOptions="Start">

                        <Border BackgroundColor="White"
                                Stroke="#E5E7EB"
                                StrokeThickness="1"
                                Padding="22"
                                StrokeShape="RoundRectangle 18">

                            <VerticalStackLayout Spacing="14">

                                <VerticalStackLayout Spacing="6">
                                    <Label Text="Informasi Sistem"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="#1F2937" />

                                    <Label Text="Detail sesi pengguna dan metode akses."
                                           FontSize="13"
                                           TextColor="#667085"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>

                                <BoxView HeightRequest="1"
                                         Color="#E5E7EB" />

                                <Grid ColumnDefinitions="*,Auto"
                                      RowDefinitions="Auto,Auto,Auto,Auto"
                                      RowSpacing="12">

                                    <Label Text="Username"
                                           TextColor="#667085" />

                                    <Label x:Name="LabelUsername"
                                           Grid.Column="1"
                                           Text="-"
                                           FontAttributes="Bold"
                                           TextColor="#1F2937" />

                                    <Label Grid.Row="1"
                                           Text="Role"
                                           TextColor="#667085" />

                                    <Label x:Name="LabelUserRole"
                                           Grid.Row="1"
                                           Grid.Column="1"
                                           Text="-"
                                           FontAttributes="Bold"
                                           TextColor="#1F2937" />

                                    <Label Grid.Row="2"
                                           Text="Verifikasi"
                                           TextColor="#667085" />

                                    <Label Grid.Row="2"
                                           Grid.Column="1"
                                           Text="Face Lock"
                                           FontAttributes="Bold"
                                           TextColor="#15803D" />

                                    <Label Grid.Row="3"
                                           Text="Metode"
                                           TextColor="#667085" />

                                    <Label Grid.Row="3"
                                           Grid.Column="1"
                                           Text="Haar + LBPH"
                                           FontAttributes="Bold"
                                           TextColor="#1F2937" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <Border x:Name="OperatorChatPanel"
                                BackgroundColor="White"
                                Stroke="#E5E7EB"
                                StrokeThickness="1"
                                Padding="22"
                                StrokeShape="RoundRectangle 18">

                            <VerticalStackLayout Spacing="14">

                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="NLP Fire Assistant"
                                               FontSize="20"
                                               FontAttributes="Bold"
                                               TextColor="#1F2937" />

                                        <Label Text="Asisten operator untuk membaca status sensor dan memberi rekomendasi tindakan."
                                               FontSize="13"
                                               TextColor="#667085"
                                               LineBreakMode="WordWrap" />
                                    </VerticalStackLayout>

                                    <Border Grid.Column="1"
                                            BackgroundColor="#EAF0F6"
                                            StrokeThickness="0"
                                            Padding="12,6"
                                            VerticalOptions="Start"
                                            StrokeShape="RoundRectangle 14">

                                        <Label Text="NLP"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="#1E3A5F" />
                                    </Border>
                                </Grid>

                                <BoxView HeightRequest="1"
                                         Color="#E5E7EB" />

                                <ScrollView x:Name="ChatScrollView"
                                            HeightRequest="210"
                                            VerticalScrollBarVisibility="Always">

                                    <VerticalStackLayout x:Name="ChatConversation"
                                                         Spacing="10">

                                        <Border BackgroundColor="#F6F7F9"
                                                StrokeThickness="0"
                                                Padding="14"
                                                StrokeShape="RoundRectangle 14">

                                            <Label Text="Halo Operator. Saya siap membantu membaca kondisi kebakaran. Coba ketik: 'status sekarang', 'rekomendasi tindakan', atau 'buat laporan'."
                                                   FontSize="13"
                                                   TextColor="#1F2937"
                                                   LineBreakMode="WordWrap" />
                                        </Border>
                                    </VerticalStackLayout>
                                </ScrollView>

                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">

                                    <Border BackgroundColor="White"
                                            Stroke="#E5E7EB"
                                            StrokeThickness="1"
                                            Padding="12,0"
                                            HeightRequest="50"
                                            StrokeShape="RoundRectangle 12">

                                        <Entry x:Name="EntryChat"
                                               Placeholder="Tanyakan kondisi sistem..."
                                               BackgroundColor="Transparent"
                                               TextColor="#1F2937"
                                               PlaceholderColor="#98A2B3"
                                               Completed="OnChatEntryCompleted" />
                                    </Border>

                                    <Button Grid.Column="1"
                                            Text="Kirim"
                                            WidthRequest="86"
                                            HeightRequest="50"
                                            BackgroundColor="#1E3A5F"
                                            TextColor="White"
                                            FontAttributes="Bold"
                                            CornerRadius="12"
                                            Clicked="OnSendChatClicked" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="WargaSipilPanel"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         Spacing="18"
                                         IsVisible="False">

                        <Border BackgroundColor="White"
                                Stroke="#E5E7EB"
                                StrokeThickness="1"
                                Padding="28"
                                StrokeShape="RoundRectangle 18">

                            <VerticalStackLayout Spacing="16">

                                <Label Text="Status Lingkungan"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="#1F2937" />

                                <Label x:Name="lblPublicStatus"
                                       Text="AMAN"
                                       FontSize="34"
                                       FontAttributes="Bold"
                                       TextColor="#15803D" />

                                <Label x:Name="lblPublicDetail"
                                       Text="Suhu -°C • Asap - ppm • Kelembapan -%"
                                       FontSize="14"
                                       TextColor="#667085"
                                       LineBreakMode="WordWrap" />

                                <BoxView HeightRequest="1"
                                         Color="#E5E7EB" />

                                <Label x:Name="lblPublicMessage"
                                       Text="Kondisi lingkungan saat ini berada dalam batas aman."
                                       FontSize="15"
                                       TextColor="#1F2937"
                                       LineBreakMode="WordWrap" />

                                <Label x:Name="lblEvacuationInstruction"
                                       Text="Tetap waspada dan pantau informasi dari sistem secara berkala."
                                       FontSize="14"
                                       TextColor="#667085"
                                       LineBreakMode="WordWrap" />

                                <Label x:Name="lblPublicFuzzyStatus"
                                       Text="-"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#15803D" />

                                <Label x:Name="lblPublicNnStatus"
                                       Text="-"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#15803D" />

                                <Label x:Name="lblPublicAiSummary"
                                       Text="Menunggu hasil analisis AI."
                                       FontSize="14"
                                       TextColor="#667085"
                                       LineBreakMode="WordWrap" />

                                <Label x:Name="lblOperatorMessage"
                                       Text="Belum ada pesan dari operator."
                                       FontSize="15"
                                       TextColor="#1F2937"
                                       LineBreakMode="WordWrap" />

                                <Label x:Name="lblOperatorMessageTime"
                                       Text="-"
                                       FontSize="13"
                                       TextColor="#667085" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <Border x:Name="DynamicMenuPanel"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            IsVisible="False"
                            BackgroundColor="White"
                            Stroke="#E5E7EB"
                            StrokeThickness="1"
                            Padding="24"
                            StrokeShape="RoundRectangle 18">

                        <ScrollView>
                            <VerticalStackLayout x:Name="DynamicMenuContent"
                                                 Spacing="16" />
                        </ScrollView>
                    </Border>

                    <ScrollView x:Name="UserProfilePanel"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                IsVisible="False">

                        <VerticalStackLayout Spacing="16">
                            <Label x:Name="ProfileFullNameLabel"
                                   Text="Nama Pengguna"
                                   FontSize="28"
                                   FontAttributes="Bold" />

                            <Label x:Name="ProfileRoleLabel"
                                   Text="Role Pengguna" />

                            <Label x:Name="ProfileSubtitleLabel"
                                   Text="Data akun pengguna." />

                            <Label x:Name="ProfileUsernameLabel" Text="Username: -" />
                            <Label x:Name="ProfileIdLabel" Text="ID Pengguna: -" />
                            <Label x:Name="ProfileStatusLabel" Text="Status Akun: Aktif" />
                            <Label x:Name="ProfileVerificationLabel" Text="Metode Verifikasi: Face Recognition" />
                            <Label x:Name="ProfileMethodLabel" Text="Metode Login: Username + Password + Face Lock" />
                            <Label x:Name="ProfileDatabaseLabel" Text="Database: SQLite Local" />
                            <Label x:Name="ProfileNameValueLabel" Text="-" />
                            <Label x:Name="ProfileRoleValueLabel" Text="-" />
                            <Label x:Name="ProfileEmailLabel" Text="-" />
                            <Label x:Name="ProfilePhoneLabel" Text="-" />
                            <Label x:Name="ProfileCreatedAtLabel" Text="-" />
                            <Label x:Name="ProfileFacePathLabel" Text="-" />
                            <Label x:Name="ProfileContactInfoLabel" Text="Informasi kontak pengguna." />
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </Grid>
        </Grid>
    </ScrollView>
</ContentPage>