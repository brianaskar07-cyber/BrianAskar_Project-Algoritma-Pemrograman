<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FIRE.App">

    <Application.Resources>
        <ResourceDictionary>

            <!-- Color Palette -->
            <Color x:Key="BgColor">#F6F7F9</Color>
            <Color x:Key="CardColor">#FFFFFF</Color>
            <Color x:Key="PrimaryColor">#1E3A5F</Color>
            <Color x:Key="PrimaryDark">#162B46</Color>
            <Color x:Key="AccentColor">#E8752F</Color>
            <Color x:Key="TextPrimary">#1F2933</Color>
            <Color x:Key="TextSecondary">#6B7280</Color>
            <Color x:Key="BorderColor">#E5E7EB</Color>
            <Color x:Key="DangerColor">#B91C1C</Color>
            <Color x:Key="SuccessColor">#15803D</Color>

            <!-- Global Page -->
            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{StaticResource BgColor}" />
            </Style>

            <!-- Label Default -->
            <Style TargetType="Label">
                <Setter Property="FontFamily" Value="OpenSansRegular" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <!-- Title Label -->
            <Style x:Key="PageTitle" TargetType="Label">
                <Setter Property="FontFamily" Value="OpenSansSemibold" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
            </Style>

            <!-- Subtitle Label -->
            <Style x:Key="PageSubtitle" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
                <Setter Property="LineHeight" Value="1.25" />
            </Style>

            <!-- Entry -->
            <Style TargetType="Entry">
                <Setter Property="BackgroundColor" Value="#FFFFFF" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="PlaceholderColor" Value="#9CA3AF" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="HeightRequest" Value="46" />
                <Setter Property="Margin" Value="0,4,0,0" />
            </Style>

            <!-- Form Input Border -->
            <Style x:Key="FormInputBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="#FFFFFF" />
                <Setter Property="Stroke" Value="#D9DEE7" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="Padding" Value="14,0" />
                <Setter Property="HeightRequest" Value="52" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="12" />
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Form Entry -->
            <Style x:Key="FormEntryStyle" TargetType="Entry">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="#1F2937" />
                <Setter Property="PlaceholderColor" Value="#98A2B3" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="HeightRequest" Value="48" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="VerticalOptions" Value="Center" />
                <Setter Property="HorizontalOptions" Value="Fill" />
                <Setter Property="ClearButtonVisibility" Value="WhileEditing" />
            </Style>

            <!-- Form Field Label -->
            <Style x:Key="FormFieldLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="#667085" />
                <Setter Property="Margin" Value="0,0,0,6" />
            </Style>

            <!-- Primary Button -->
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="HeightRequest" Value="46" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Padding" Value="18,0" />
            </Style>

            <!-- Secondary Button -->
            <Style x:Key="SecondaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#EEF2F6" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryColor}" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="HeightRequest" Value="44" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

            <!-- Text Button -->
            <Style x:Key="TextButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="HeightRequest" Value="38" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>

</Application>