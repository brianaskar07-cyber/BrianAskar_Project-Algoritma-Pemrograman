<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FIRE"
             x:Class="FIRE.MainPage"
             Title="Login"
             BackgroundColor="#F6F7F9">

    <Grid>

        <!-- LAYOUT DESKTOP / WINDOWS -->
        <Grid IsVisible="{OnIdiom Phone=False, Default=True}"
              Padding="32"
              ColumnDefinitions="1.2*,0.9*"
              ColumnSpacing="32">

            <!-- Panel Kiri -->
            <Border Grid.Column="0"
                    BackgroundColor="#1E3A5F"
                    StrokeThickness="0"
                    Padding="40"
                    StrokeShape="RoundRectangle 22">

                <Grid RowDefinitions="*,Auto">
                    <VerticalStackLayout VerticalOptions="Center"
                                         Spacing="24">

                        <Border BackgroundColor="#496887"
                                StrokeThickness="0"
                                Padding="14,8"
                                HorizontalOptions="Start"
                                StrokeShape="RoundRectangle 18">
                            <Label Text="FIRE SECURITY SYSTEM"
                                   TextColor="White"
                                   FontSize="13"
                                   FontAttributes="Bold" />
                        </Border>

                        <Label Text="KONDISI LINGKUNGAN SEKITAR"
                               TextColor="White"
                               FontSize="34"
                               FontAttributes="Bold"
                               LineBreakMode="WordWrap" />

                        <Label Text="Masuk menggunakan akun terdaftar, lalu lakukan verifikasi wajah melalui kamera perangkat."
                               TextColor="#D7E2EF"
                               FontSize="16"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <HorizontalStackLayout Grid.Row="1"
                                           Spacing="10"
                                           VerticalOptions="End">
                        <BoxView WidthRequest="8"
                                 HeightRequest="8"
                                 CornerRadius="4"
                                 Color="#F97316"
                                 VerticalOptions="Center" />

                        <Label Text="Live face recognition aktif setelah proses login."
                               TextColor="#D7E2EF"
                               FontSize="14" />
                    </HorizontalStackLayout>
                </Grid>
            </Border>

            <!-- Form Login Desktop -->
            <Border Grid.Column="1"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    Padding="36"
                    VerticalOptions="Center"
                    StrokeShape="RoundRectangle 22">

                <VerticalStackLayout Spacing="20">

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Masuk Sistem"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="#1F2937" />

                        <Label Text="Gunakan username dan password yang sudah terdaftar."
                               FontSize="14"
                               TextColor="#667085" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1"
                             Color="#E5E7EB"
                             Margin="0,8,0,8" />

                    <VerticalStackLayout Spacing="14">

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Username"
                                   FontSize="13"
                                   TextColor="#667085" />

                            <Border BackgroundColor="White"
                                    Stroke="#D9DEE7"
                                    StrokeThickness="1"
                                    Padding="14,0"
                                    HeightRequest="52"
                                    StrokeShape="RoundRectangle 12">

                            <local:BorderlessEntry x:Name="EntryUsername"
                                                   Placeholder="Masukkan username"
                                                   BackgroundColor="Transparent"
                                                   TextColor="#1F2937"
                                                   PlaceholderColor="#98A2B3"
                                                   HeightRequest="48"
                                                   Margin="0"
                                                   VerticalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Password"
                                   FontSize="13"
                                   TextColor="#667085" />

                            <Border BackgroundColor="White"
                                    Stroke="#D9DEE7"
                                    StrokeThickness="1"
                                    Padding="14,0"
                                    HeightRequest="52"
                                    StrokeShape="RoundRectangle 12">

                                <local:BorderlessEntry x:Name="EntryPassword"
                                                        Placeholder="Masukkan password"
                                                        IsPassword="True"
                                                        BackgroundColor="Transparent"
                                                        TextColor="#1F2937"
                                                        PlaceholderColor="#98A2B3"
                                                        HeightRequest="48"
                                                        Margin="0"
                                                        VerticalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <Button Text="Masuk"
                            HeightRequest="52"
                            BackgroundColor="#1E3A5F"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            Clicked="OnLoginClicked" />

                    <Button Text="Belum punya akun? Daftar"
                            HeightRequest="46"
                            BackgroundColor="White"
                            TextColor="#667085"
                            BorderColor="#E5E7EB"
                            BorderWidth="1"
                            CornerRadius="8"
                            Clicked="OnGoToRegisterClicked" />

                </VerticalStackLayout>
            </Border>
        </Grid>


        <!-- LAYOUT HP ANDROID -->
        <ScrollView IsVisible="{OnIdiom Phone=True, Default=False}">
            <VerticalStackLayout Padding="22,28"
                                 Spacing="20">

                <!-- Header Mobile -->
                <Border BackgroundColor="#1E3A5F"
                        StrokeThickness="0"
                        Padding="24"
                        StrokeShape="RoundRectangle 22">

                    <VerticalStackLayout Spacing="14">

                        <Border BackgroundColor="#496887"
                                StrokeThickness="0"
                                Padding="12,7"
                                HorizontalOptions="Start"
                                StrokeShape="RoundRectangle 16">
                            <Label Text="FIRE SECURITY SYSTEM"
                                   TextColor="White"
                                   FontSize="12"
                                   FontAttributes="Bold" />
                        </Border>

                        <Label Text="Kondisi Lingkungan Sekitar"
                               TextColor="White"
                               FontSize="26"
                               FontAttributes="Bold"
                               LineBreakMode="WordWrap" />

                        <Label Text="Masuk menggunakan akun terdaftar dan lanjutkan verifikasi wajah."
                               TextColor="#D7E2EF"
                               FontSize="14"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Form Login Mobile -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="24"
                        StrokeShape="RoundRectangle 22">

                    <VerticalStackLayout Spacing="18">

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Masuk Sistem"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="#1F2937" />

                            <Label Text="Gunakan username dan password yang sudah terdaftar."
                                   FontSize="14"
                                   TextColor="#667085"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1"
                                 Color="#E5E7EB"
                                 Margin="0,4,0,4" />

                        <!-- Username -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Username"
                                   FontSize="13"
                                   TextColor="#667085" />

                            <Border BackgroundColor="White"
                                    Stroke="#D9DEE7"
                                    StrokeThickness="1"
                                    Padding="14,0"
                                    HeightRequest="52"
                                    StrokeShape="RoundRectangle 12">

                                <Entry x:Name="EntryUsernameMobile"
                                       Placeholder="Masukkan username"
                                       BackgroundColor="Transparent"
                                       TextColor="#1F2937"
                                       PlaceholderColor="#98A2B3"
                                       HeightRequest="48" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Password"
                                   FontSize="13"
                                   TextColor="#667085" />

                            <Border BackgroundColor="White"
                                    Stroke="#D9DEE7"
                                    StrokeThickness="1"
                                    Padding="14,0"
                                    HeightRequest="52"
                                    StrokeShape="RoundRectangle 12">

                                <Entry x:Name="EntryPasswordMobile"
                                       Placeholder="Masukkan password"
                                       IsPassword="True"
                                       BackgroundColor="Transparent"
                                       TextColor="#1F2937"
                                       PlaceholderColor="#98A2B3"
                                       HeightRequest="48" />
                            </Border>
                        </VerticalStackLayout>

                        <Button Text="Masuk"
                                HeightRequest="52"
                                BackgroundColor="#1E3A5F"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="12"
                                Clicked="OnLoginClicked" />

                        <Button Text="Belum punya akun? Daftar"
                                HeightRequest="46"
                                BackgroundColor="White"
                                TextColor="#667085"
                                BorderColor="#E5E7EB"
                                BorderWidth="1"
                                CornerRadius="8"
                                Clicked="OnGoToRegisterClicked" />

                    </VerticalStackLayout>
                </Border>

                <Label Text="Live face recognition aktif setelah proses login."
                       FontSize="13"
                       TextColor="#667085"
                       HorizontalTextAlignment="Center"
                       Margin="0,4,0,16" />

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>