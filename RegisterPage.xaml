<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FIRE.RegisterPage"
             Title="Registrasi"
             BackgroundColor="#F6EDED">

    <ScrollView VerticalScrollBarVisibility="Always">

        <Grid Padding="32"
              RowDefinitions="Auto,Auto"
              RowSpacing="24">

            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto">

                <VerticalStackLayout Spacing="6">
                    <Label Text="Registrasi Pengguna"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#1F2937" />

                    <Label Text="Buat akun baru dan simpan data wajah untuk proses verifikasi."
                           FontSize="14"
                           TextColor="#667085" />
                </VerticalStackLayout>

                <Border Grid.Column="1"
                        BackgroundColor="#FFF1E8"
                        StrokeThickness="0"
                        Padding="16,10"
                        VerticalOptions="Start"
                        StrokeShape="RoundRectangle 22">

                    <Label Text="ENROLLMENT"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#E8752F" />
                </Border>
            </Grid>

            <Grid Grid.Row="1"
                  ColumnDefinitions="0.85*,1.05*"
                  ColumnSpacing="28">

                <Border Grid.Column="0"
                        BackgroundColor="White"
                        Stroke="#E5E7EB"
                        StrokeThickness="1"
                        Padding="28"
                        StrokeShape="RoundRectangle 18">

                    <VerticalStackLayout Spacing="20">

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Informasi Akun"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#1F2937" />

                            <Label Text="Masukkan data pengguna sesuai hak akses."
                                   FontSize="14"
                                   TextColor="#667085" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1"
                                 Color="#E5E7EB" />

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Username"
                                   FontSize="13"
                                   TextColor="#667085" />

                            <Border BackgroundColor="White"
                                    Stroke="#D9DEE7"
                                    StrokeThickness="1"
                                    Padding="14,0"
                                    HeightRequest="52"
                                    StrokeShape="RoundRectangle 12">

                                <Entry x:Name="EntryUsername"
                                       Placeholder="Buat username"
                                       BackgroundColor="Transparent"
                                       TextColor="#1F2937"
                                       PlaceholderColor="#98A2B3"
                                       HeightRequest="48" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Password"
                                   FontSize="13"
                                   TextColor="#667085" />

                            <Border BackgroundColor="White"
                                    Stroke="#D9DEE7"
                                    StrokeThickness="1"
                                    Padding="14,0"
                                    HeightRequest="52"
                                    StrokeShape="RoundRectangle 12">

                                <Entry x:Name="EntryPassword"
                                       Placeholder="Buat password"
                                       IsPassword="True"
                                       BackgroundColor="Transparent"
                                       TextColor="#1F2937"
                                       PlaceholderColor="#98A2B3"
                                       HeightRequest="48" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Hak Akses"
                                   FontSize="13"
                                   TextColor="#667085" />

                            <Border BackgroundColor="White"
                                    Stroke="#D9DEE7"
                                    StrokeThickness="1"
                                    Padding="14,0"
                                    HeightRequest="52"
                                    StrokeShape="RoundRectangle 12">

                                <Grid ColumnDefinitions="*,Auto"
                                      HeightRequest="48">

                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSelectRoleTapped" />
                                    </Grid.GestureRecognizers>

                                    <Label x:Name="LabelRoleValue"
                                           Text="Pilih hak akses"
                                           TextColor="#667085"
                                           FontSize="14"
                                           VerticalOptions="Center" />

                                    <Label Grid.Column="1"
                                           Text="⌄"
                                           TextColor="#667085"
                                           FontSize="18"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <Button Text="Simpan dan Daftarkan"
                                HeightRequest="52"
                                BackgroundColor="#1E3A5F"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="12"
                                Clicked="OnRegisterClicked" />

                        <Button Text="Kembali ke Login"
                                HeightRequest="46"
                                BackgroundColor="White"
                                TextColor="#667085"
                                BorderColor="#E5E7EB"
                                BorderWidth="1"
                                CornerRadius="8"
                                Clicked="OnBackToLoginClicked" />

                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        BackgroundColor="White"
                        Stroke="#E5E7EB"
                        StrokeThickness="1"
                        Padding="28"
                        StrokeShape="RoundRectangle 18">

                    <VerticalStackLayout Spacing="18">

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Data Wajah"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#1F2937" />

                            <Label Text="Ambil foto wajah dengan posisi lurus dan pencahayaan cukup. Foto ini akan digunakan sebagai data pembanding saat login."
                                   FontSize="14"
                                   TextColor="#667085"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>

                        <Border BackgroundColor="#0F172A"
                                StrokeThickness="0"
                                HeightRequest="360"
                                StrokeShape="RoundRectangle 14">

                            <Grid>

                                <Image x:Name="CameraPreview"
                                       Aspect="AspectFill" />

                                <VerticalStackLayout HorizontalOptions="Center"
                                                     VerticalOptions="Center"
                                                     Spacing="8">

                                    <Label Text="Preview Foto Wajah"
                                           TextColor="White"
                                           FontSize="15"
                                           HorizontalTextAlignment="Center" />

                                    <Label Text="Foto akan tampil di sini setelah diambil."
                                           TextColor="#CBD5E1"
                                           FontSize="13"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>

                            </Grid>
                        </Border>

                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">

                            <Button Text="Ambil Foto Wajah"
                                    HeightRequest="48"
                                    BackgroundColor="#EAF0F6"
                                    TextColor="#1E3A5F"
                                    FontAttributes="Bold"
                                    CornerRadius="12"
                                    Clicked="OnCaptureFaceClicked" />

                            <Button Grid.Column="1"
                                    Text="Kamera"
                                    HeightRequest="48"
                                    BackgroundColor="White"
                                    TextColor="#667085"
                                    BorderColor="#E5E7EB"
                                    BorderWidth="1"
                                    CornerRadius="12"
                                    Clicked="OnCaptureFaceClicked" />
                        </Grid>

                        <Border BackgroundColor="#F8FAFC"
                                StrokeThickness="0"
                                Padding="16"
                                StrokeShape="RoundRectangle 14">

                            <Label Text="Pastikan wajah terlihat jelas, tidak terlalu jauh, dan tidak tertutup objek. Gunakan pencahayaan yang cukup agar verifikasi wajah lebih akurat."
                                   FontSize="13"
                                   TextColor="#667085"
                                   LineBreakMode="WordWrap" />
                        </Border>

                    </VerticalStackLayout>
                </Border>

            </Grid>
        </Grid>
    </ScrollView>
</ContentPage>